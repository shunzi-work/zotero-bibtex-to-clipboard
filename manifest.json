{
  "manifest_version": 2,
  "name": "BibClip",
  "version": "2.0.0",
  "description": "One-click BibTeX copy for Zotero with LaTeX-safe encoding and smart citation keys.",
  "author": "Custom Plugin",
  "applications": {
    "zotero": {
      "id": "bibclip@zotero.plugin",
      "update_url": "https://raw.githubusercontent.com/shunzi-work/bibclip/main/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "8.*"
    }
  }
}